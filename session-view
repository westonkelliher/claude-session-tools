def pretty_model(mid):
    """Turn a raw model id (claude-opus-4-8) into a label (Opus 4.8)."""
    if not mid or mid.startswith("<"):
        return None
    fam = next((f for f in ("opus", "sonnet", "haiku", "fable") if f in mid.lower()), None)
    m = re.search(r"(?<![0-9])([0-9])-([0-9])(?![0-9])", mid)
    ver = ".".join(m.groups()) if m else None
    if fam and ver:
        return f"{fam.capitalize()} {ver}"
    return fam.capitalize() if fam else mid


def detect_model(entries):
    """The model that produced most assistant turns in the session."""
    c = Counter()
    for e in entries:
        msg = e.get("message") or {}
        mid = msg.get("model") if isinstance(msg, dict) else None
        if mid and not mid.startswith("<"):
            c[mid] += 1
    return c.most_common(1)[0][0] if c else None

