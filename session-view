    )
    if result_block is not None:
        content = tool_result_text(result_block)
        is_err = bool(result_block.get("is_error"))
        label = "result (error)" if is_err else "result"
        first_line = short(content or "", 160) or "(empty)"
        cls = "result error" if is_err else "result"
        body += (
            f'<details class="{cls}"><summary>{label} — {esc(first_line)}</summary>'
            f'<pre class="raw">{esc(content)}</pre></details>'
        )
    else:
        body += '<div class="kv pending">(no result)</div>'

    name_cls = "tool-" + re.sub(r"[^a-z0-9]", "", name.lower())
    inner = (
        f'<div class="toolhead"><span class="name {name_cls}">{esc(name)}</span>'
        f'<span class="toolsummary">{summary}</span></div>'
        f"{body}"
    )
    return card("tool", ts, inner)


def render_orphan_result(block, ts):
    content = tool_result_text(block)
    is_err = bool(block.get("is_error"))
    extra = "error" if is_err else ""
    label = "result (error, orphan)" if is_err else "result (orphan)"
    first_line = short(content or "", 160) or "(empty)"
    inner = (
        f"<details><summary>{label} — {esc(first_line)}</summary>"
        f'<pre class="raw">{esc(content)}</pre></details>'
    )
    return card("toolresult", ts, inner, extra)


def render_entries(entries):
    # First pass: collect tool_results by tool_use_id.
    results_by_id = {}
    for entry in entries:
        t = entry.get("type")
        if t not in ("user", "assistant", "system"):
            continue
        msg = entry.get("message", {}) or {}
        content = msg.get("content")
        if not isinstance(content, list):
            continue
        for block in content:
            if isinstance(block, dict) and block.get("type") == "tool_result":
                tid = block.get("tool_use_id")
                if tid:
                    results_by_id[tid] = (block, entry.get("timestamp", ""))

    seen_use_ids = set()
    out = []
    turn_count = 0
    tool_count = 0

    for entry in entries:
        t = entry.get("type")
        if t in SKIP_TYPES or t not in ("user", "assistant", "system"):
            continue
        msg = entry.get("message", {}) or {}
        content = msg.get("content")
        ts = entry.get("timestamp", "")

        if isinstance(content, str):
            body = f'<div class="md">{render_markdown(content)}</div>'
            out.append(card(t, ts, body))
            turn_count += 1
            continue

        if not isinstance(content, list):
            continue

        role_buffer = []

        def flush_role():
            nonlocal turn_count
            joined = "\n".join(s for s in role_buffer if s.strip())
            if joined.strip():
                out.append(card(t, ts, joined))
                turn_count += 1
            role_buffer.clear()

        for block in content:
            if not isinstance(block, dict):
                continue
            btype = block.get("type")
            if btype == "thinking":
                rendered = render_thinking(block)
                if rendered:
                    role_buffer.append(rendered)
            elif btype == "text":
                text = (block.get("text") or "").strip()
                if text:
                    role_buffer.append(f'<div class="md">{render_markdown(text)}</div>')
            elif btype == "tool_use":
                flush_role()
                tid = block.get("id")
                seen_use_ids.add(tid)
                result_pair = results_by_id.get(tid)
                result_block = result_pair[0] if result_pair else None
                out.append(render_tool_pair(block, result_block, ts))
                tool_count += 1
            elif btype == "tool_result":
                tid = block.get("tool_use_id")
                if tid in seen_use_ids:
                    continue  # already rendered alongside its tool_use
                flush_role()
                out.append(render_orphan_result(block, ts))
        flush_role()

    return out, turn_count, tool_count


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("jsonl", type=Path)
    ap.add_argument("-o", "--output", type=Path)
    ap.add_argument("--no-open", action="store_true", help="don't open the result in a browser")
    args = ap.parse_args()

    entries = []
    with args.jsonl.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entries.append(json.loads(line))
            except json.JSONDecodeError:
                continue

    rendered, turn_count, tool_count = render_entries(entries)
    title = args.jsonl.name
    model = pretty_model(detect_model(entries))
    model_chip = f'<span class="model">{esc(model)}</span>' if model else ""

    page = f"""<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{esc(title)}</title>
{THEME_HEAD_JS}
<style>{CSS}</style>
</head>
<body class="summary">
<header class="topbar">
  <span class="name">{esc(title)}</span>
  <span class="stats">{turn_count} role turns • {tool_count} tool calls</span>
  {model_chip}
  <span class="spacer"></span>
  {THEME_BUTTON}
</header>
<main>
{chr(10).join(rendered)}
</main>
{EXPAND_SCRIPT}
</body>
</html>
"""

    out = args.output or args.jsonl.with_suffix(".html")
    out.write_text(page, encoding="utf-8")
    print(f"wrote {out}", file=sys.stderr)
    if not args.no_open:
        webbrowser.open(out.resolve().as_uri())


if __name__ == "__main__":
    main()
