def esc(s):
    return html.escape("" if s is None else str(s), quote=True)


def short(s, n=120):
    s = (s or "").replace("\n", " ").strip()
    return s if len(s) <= n else s[:n] + "…"


def md_inline(text):
    parts = re.split(r"(`[^`\n]+`)", text)
    out = []
    for j, part in enumerate(parts):
        if j % 2 == 1:
            out.append(f"<code>{esc(part[1:-1])}</code>")
        else:
            t = esc(part)
            t = re.sub(r"\*\*([^*\n]+)\*\*", r"<strong>\1</strong>", t)
            t = re.sub(r"(?<!\*)\*([^*\n]+)\*(?!\*)", r"<em>\1</em>", t)
            t = re.sub(r"\[([^\]\n]+)\]\(([^)\s]+)\)", r'<a href="\2">\1</a>', t)
            out.append(t)
    return "".join(out)


def render_markdown(text):
    """Minimal markdown -> HTML. Handles fences, headers, lists, paragraphs, inline code/bold/italic/links."""
    if not text:
        return ""
    lines = text.split("\n")
    out = []
    in_list = None

    def close_list():
        nonlocal in_list
        if in_list:
            out.append(f"</{in_list}>")
            in_list = None

    i = 0
    while i < len(lines):
        line = lines[i]
        m = re.match(r"^```(\w*)\s*$", line)
        if m:
            close_list()
            i += 1
            buf = []
            while i < len(lines) and not re.match(r"^```\s*$", lines[i]):
                buf.append(lines[i])
                i += 1
            i += 1
            out.append(f"<pre><code>{esc(chr(10).join(buf))}</code></pre>")
            continue
        m = re.match(r"^(#{1,4})\s+(.*)$", line)
        if m:
            close_list()
            level = len(m.group(1))
            out.append(f"<h{level}>{md_inline(m.group(2))}</h{level}>")
            i += 1
            continue
        m = re.match(r"^\s*[-*]\s+(.*)$", line)
        if m:
            if in_list != "ul":
                close_list()
                out.append("<ul>")
                in_list = "ul"
            out.append(f"<li>{md_inline(m.group(1))}</li>")
            i += 1
            continue
        m = re.match(r"^\s*\d+\.\s+(.*)$", line)
        if m:
            if in_list != "ol":
                close_list()
                out.append("<ol>")
                in_list = "ol"
            out.append(f"<li>{md_inline(m.group(1))}</li>")
            i += 1
            continue
        if not line.strip():
            close_list()
            i += 1
            continue
        close_list()
        para = [line]
        i += 1
        while i < len(lines) and lines[i].strip() and not re.match(r"^(```|#{1,4}\s|\s*[-*]\s|\s*\d+\.\s)", lines[i]):
            para.append(lines[i])
            i += 1
        joined = "\n".join(para)
        out.append("<p>" + md_inline(joined).replace("\n", "<br>") + "</p>")

    close_list()
    return "\n".join(out)


def card(role, ts, body_html, extra_class=""):
    cls = f"card {role}"
    if extra_class:
        cls += " " + extra_class
    return (
        f'<section class="{cls}">'
        f'<div class="card-header"><span class="role">{role}</span><span class="ts">{esc(ts)}</span></div>'
        f"{body_html}</section>"
    )


def render_thinking(block):
    text = (block.get("thinking") or "").strip()
    if not text:
        return ""
    return (
        f'<details class="thinking">'
        f"<summary>thinking — {esc(short(text, 140))}</summary>"
        f'<div class="body">{esc(text)}</div>'
        f"</details>"
    )


def tool_use_summary_html(block):
    """Return HTML-safe summary (already escaped/marked-up)."""
    name = block.get("name", "?")
    inp = block.get("input", {}) or {}
    if name in ("Write", "Edit", "NotebookEdit", "Read"):
        fp = inp.get("file_path", "") or ""
        if "/" in fp:
            head, _, tail = fp.rpartition("/")
            return f"{esc(head)}/<strong>{esc(tail)}</strong>"
        return f"<strong>{esc(fp)}</strong>"
    if name == "Bash":
        return esc(short(inp.get("description") or inp.get("command", ""), 100))
    first_key = next(iter(inp), None)
    if first_key:
        return esc(f"{first_key}={short(str(inp[first_key]), 80)}")
    return ""


def tool_use_body(block):
    name = block.get("name", "?")
    inp = block.get("input", {}) or {}
    if name in ("Write", "Edit", "NotebookEdit"):
        fp = inp.get("file_path", "")
        rows = [f'<div class="kv"><b>file:</b> {esc(fp)}</div>']
        if "old_string" in inp:
            rows.append('<div class="kv"><b>old:</b></div>')
            rows.append(f'<pre class="raw">{esc(inp.get("old_string", ""))}</pre>')
            rows.append('<div class="kv"><b>new:</b></div>')
            rows.append(f'<pre class="raw">{esc(inp.get("new_string", ""))}</pre>')
        elif "content" in inp:
            rows.append('<div class="kv"><b>content:</b></div>')
            rows.append(f'<pre class="raw">{esc(inp.get("content", ""))}</pre>')
        return "\n".join(rows)
    if name == "Bash":
        cmd = inp.get("command", "")
        desc = inp.get("description", "")
        out = ""
        if desc:
            out += f'<div class="kv"><b>desc:</b> {esc(desc)}</div>'
        out += f'<pre class="raw">{esc(cmd)}</pre>'
        return out
    if name == "Read":
        fp = inp.get("file_path", "")
        out = f'<div class="kv"><b>file:</b> {esc(fp)}</div>'
        for k in ("offset", "limit", "pages"):
            if k in inp:
                out += f'<div class="kv"><b>{k}:</b> {esc(inp[k])}</div>'
        return out
    return f'<pre class="raw">{esc(json.dumps(inp, indent=2))}</pre>'


def tool_result_text(block):
    content = block.get("content", "")
    if isinstance(content, list):
        parts = []
        for c in content:
            if isinstance(c, dict):
                parts.append(c.get("text", json.dumps(c)))
            else:
                parts.append(str(c))
        content = "\n".join(parts)
    return content


