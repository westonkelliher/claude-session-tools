function setMore(p){{
  const b=p.querySelector('.more'); if(!b)return;
  const all=p.classList.contains('show-all');
  b.textContent=all?'▴ show less':('▾ show '+b.dataset.n+' more');
}}
function toggleMore(b){{
  const p=b.closest('.proj');
  p.classList.toggle('show-all');
  p.dataset.manual=p.classList.contains('show-all')?'1':'';
  setMore(p);
}}
q.addEventListener('input',()=>{{
  const t=q.value.trim().toLowerCase();
  document.querySelectorAll('.proj').forEach(p=>{{
    let any=false;
    p.querySelectorAll('.row').forEach(r=>{{
      const hit=!t||r.dataset.s.includes(t);
      r.classList.toggle('hidden',!hit); if(hit)any=true;
    }});
    // while filtering, lift the 5-row cap so all matches show
    p.classList.toggle('show-all', t?true:(p.dataset.manual==='1'));
    setMore(p);
    const phit=any||(!t)||p.dataset.s.includes(t);
    p.classList.toggle('hidden',!phit);
    if(t&&any)p.open=true;
  }});
