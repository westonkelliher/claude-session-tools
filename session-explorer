            f'<summary><span class="path">{esc(p["label"])}</span>'
            f'<span class="count">{n} sessions</span></summary>'
            + "".join(items) + more + "</details>"
        )
    body = "\n".join(rows_html) or '<div class="empty">No sessions found.</div>'
    return f"""<!doctype html><html><head><meta charset="utf-8">
