def render_session(path):
    p = Path(path)
    if not p.is_file() or p.suffix != ".jsonl" or PROJECTS not in p.resolve().parents:
        return None
    entries = []
    with p.open(encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    entries.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    rendered, turns, tools = sv.render_entries(entries)
    meta = scan_session(p)
    title = title_for(meta)
    backbar = (
        '<header class="topbar">'
        '<a href="/" class="back">&larr; all sessions</a>'
        f'<span class="name">{esc(title)}</span>'
        f'<span class="stats">{turns} turns • {tools} tools • {esc(meta.get("cwd") or "")}</span>'
        '<span class="spacer"></span>'
        f"{sv.THEME_BUTTON}"
        "</header>"
    )
    return (
        f'<!doctype html><html><head><meta charset="utf-8"><title>{esc(title)}</title>'
        f"{sv.THEME_HEAD_JS}<style>{sv.CSS}</style></head><body class=\"summary\">{backbar}"
        f'<main>{chr(10).join(rendered)}</main>{sv.EXPAND_SCRIPT}</body></html>'
    )


class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a):
        pass

    def _send(self, body, code=200, ctype="text/html; charset=utf-8"):
        data = body.encode("utf-8") if isinstance(body, str) else body
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        u = urllib.parse.urlparse(self.path)
        try:
            if u.path == "/":
                self._send(render_index())
            elif u.path == "/s":
                f = urllib.parse.parse_qs(u.query).get("f", [""])[0]
                page = render_session(f)
                if page is None:
                    self._send("not found", 404, "text/plain")
                else:
                    self._send(page)
            else:
                self._send("not found", 404, "text/plain")
        except BrokenPipeError:
            pass
        except Exception as e:  # noqa: BLE001 — keep server alive, report in browser
            self._send(f"<pre>error: {esc(repr(e))}</pre>", 500)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=0, help="port (default: auto)")
    ap.add_argument("--no-open", action="store_true")
    args = ap.parse_args()

    if not PROJECTS.exists():
        print(f"no projects dir at {PROJECTS}", file=sys.stderr)
        sys.exit(1)

    srv = ThreadingHTTPServer(("127.0.0.1", args.port), Handler)
    port = srv.server_address[1]
    url = f"http://127.0.0.1:{port}/"
    print(f"session-explorer → {url}  (ctrl-c to stop)", file=sys.stderr)
    if not args.no_open:
        webbrowser.open(url)
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        print("\nbye", file=sys.stderr)


if __name__ == "__main__":
    main()
