            href = "/s?f=" + urllib.parse.quote(m["file"])
            search = esc((title + " " + (sub or "") + " " + m["name"] + " " + p["label"]).lower())
            items.append(
                f'<a class="row{over}" href="{href}" target="_blank" data-s="{search}">'
                f'<span class="dot" style="background:{esc(color)}"></span>'
                f'<span class="title">{tw[0]}{esc(title)}{tw[1]}'
                + (f' <span class="sub">— {esc(sub[:80])}</span>' if sub else "")
                + "</span>"
                f'{branch}{gbadge}'
                f'<span class="msgpair">'
                f'<span class="msgs" style="{chip_style(m["msgs"], (150,140,170), (190,150,255), 300)}" '
                f'title="total messages">{m["msgs"]} msg</span>'
                f'<span class="umsgs" style="{chip_style(m["user_msgs"], (140,150,175), (120,175,255), 30)}" '
                f'title="user messages">{m["user_msgs"]} usr</span>'
                f'</span>'
                f'<span class="age" style="{age_style(m["last_ts"])}">'
                f'{esc(rel_age(m["last_ts"]))}</span>'
                "</a>"
            )
        open_attr = " open" if pi == 0 else ""
        n = len(p["sessions"])
        more = (f'<button class="more" onclick="toggleMore(this)" '
