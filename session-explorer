  <span class="name">session explorer</span>
  <span class="stats">{len(projects)} projects • {nsess} sessions</span>
  <span class="spacer"></span>
  <input id="q" placeholder="filter sessions…" autofocus>
  <button onclick="document.querySelectorAll('.proj').forEach(d=>d.open=true)">expand</button>
  <button onclick="document.querySelectorAll('.proj').forEach(d=>d.open=false)">collapse</button>
  {sv.THEME_BUTTON}
</header>
<main>{body}</main>
<script>
