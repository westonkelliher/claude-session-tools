def esc(s):
    return html.escape("" if s is None else str(s), quote=True)


def rel_age(ts):
    if not ts:
        return ""
    d = time.time() - ts
    if d < 90:
        return "now"
    for unit, sec in (("d", 86400), ("h", 3600), ("m", 60)):
        if d >= sec:
            return f"{int(d // sec)}{unit}"
    return "now"


def chip_style(n, dim, bright, cap):
    """Muted-gray-tinted (low) -> vivid (high) ramp; max reached at `cap`."""
    t = min(1.0, math.sqrt(max(n, 0)) / math.sqrt(cap))
    L = lambda i: dim[i] + (bright[i] - dim[i]) * t
    r, g, b = L(0), L(1), L(2)
    return (f"background:rgba({r:.0f},{g:.0f},{b:.0f},{0.06 + 0.20 * t:.3f});"
            f"border-color:rgba({r:.0f},{g:.0f},{b:.0f},{0.50 * t:.3f});"
            f"color:rgb({r:.0f},{g:.0f},{b:.0f})")


# Anchors mapped to evenly spaced positions so these ages are equally
# distinguishable; t is piecewise-linear in log(seconds) between them.
_AGE_ANCHORS = [(120, 0.0), (1200, 0.2), (28800, 0.4),
                (86400, 0.6), (259200, 0.8), (691200, 1.0)]


def age_style(ts):
    """Continuous lime-green (fresh) -> teal (stale) ramp."""
    if not ts:
        return ""
    d = max(time.time() - ts, 1)
    ld = math.log(d)
    t = _AGE_ANCHORS[-1][1]
    if ld <= math.log(_AGE_ANCHORS[0][0]):
        t = 0.0
    else:
        for (s0, t0), (s1, t1) in zip(_AGE_ANCHORS, _AGE_ANCHORS[1:]):
            if ld <= math.log(s1):
                l0, l1 = math.log(s0), math.log(s1)
                t = t0 + (t1 - t0) * (ld - l0) / (l1 - l0)
                break
    lerp = lambda a, b: a + (b - a) * t
    r, g, b = lerp(190, 88), lerp(240, 176), lerp(60, 170)
    tr, tg, tb = lerp(205, 96), lerp(250, 180), lerp(70, 176)
    return (f"background:rgba({r:.0f},{g:.0f},{b:.0f},{lerp(0.26, 0.07):.3f});"
            f"border-color:rgba({r:.0f},{g:.0f},{b:.0f},{lerp(0.50, 0.0):.3f});"
            f"color:rgb({tr:.0f},{tg:.0f},{tb:.0f})")


def first_human_prompt(text):
    """Strip command/reminder wrappers; return first real human line or ''."""
    if not isinstance(text, str):
        return ""
    cmd = re.search(r"<command-name>\s*(.*?)\s*</command-name>", text)
    args = re.search(r"<command-args>\s*(.*?)\s*</command-args>", text)
    if cmd:
        c = cmd.group(1).strip()
        a = (args.group(1).strip() if args else "")
        return (c + (" " + a if a else "")).strip()
    t = re.sub(r"<(system-reminder|command-[^>]*|local-command-[^>]*)>.*?</\1>", "", text, flags=re.S)
    t = re.sub(r"<[^>]+>", "", t).strip()
    return t


_cache = {}  # path -> (mtime, meta)


def scan_session(path):
    st = path.stat()
    hit = _cache.get(str(path))
    if hit and hit[0] == st.st_mtime:
        return hit[1]

    meta = {
        "file": str(path), "name": path.stem, "size": st.st_size,
        "cwd": None, "branch": None, "color": None, "version": None,
        "custom_title": None, "ai_title": None, "last_prompt": None,
        "first_prompt": "", "msgs": 0, "user_msgs": 0, "last_ts": st.st_mtime, "branched": False,
    }
    children = {}
    last_iso = None
    try:
        with path.open(encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                t = d.get("type")
                if t == "ai-title":
                    meta["ai_title"] = d.get("aiTitle")
                elif t == "custom-title":
                    meta["custom_title"] = d.get("customTitle")
                elif t == "agent-color":
                    meta["color"] = d.get("agentColor")
                elif t == "last-prompt":
                    meta["last_prompt"] = d.get("lastPrompt")
                elif t in ("user", "assistant"):
                    meta["msgs"] += 1
                    if not meta["cwd"] and d.get("cwd"):
                        meta["cwd"] = d.get("cwd")
                        meta["branch"] = d.get("gitBranch")
                        meta["version"] = d.get("version")
                    p = d.get("parentUuid")
                    if p:
                        children[p] = children.get(p, 0) + 1
                    if t == "user":
                        c = d.get("message", {}).get("content")
                        if isinstance(c, list):
                            c = " ".join(b.get("text", "") for b in c
                                         if isinstance(b, dict) and b.get("type") == "text")
                        # count genuine human turns (skip tool-result-only messages)
                        if isinstance(c, str) and c.strip():
                            meta["user_msgs"] += 1
                        if not meta["first_prompt"]:
                            meta["first_prompt"] = first_human_prompt(c)
                    if d.get("timestamp"):
                        last_iso = d["timestamp"]
    except OSError:
        return meta

    meta["branched"] = any(v > 1 for v in children.values())
    if last_iso:
        try:
            meta["last_ts"] = datetime.fromisoformat(
                last_iso.replace("Z", "+00:00")).timestamp()
        except ValueError:
            pass
    _cache[str(path)] = (st.st_mtime, meta)
    return meta


def title_for(m):
    return (m["custom_title"] or m["ai_title"] or m["first_prompt"]
            or m["last_prompt"] or m["name"][:8])


def scan_all():
    projects = []
    if not PROJECTS.exists():
        return projects
    for pdir in PROJECTS.iterdir():
        if not pdir.is_dir():
            continue
        sessions = [scan_session(f) for f in pdir.glob("*.jsonl")]
        if not sessions:
            continue
        sessions.sort(key=lambda m: m["last_ts"], reverse=True)
        cwd = next((s["cwd"] for s in sessions if s["cwd"]), None)
        label = cwd or ("/" + pdir.name.lstrip("-").replace("-", "/"))
        projects.append({
            "label": label, "sessions": sessions,
            "last_ts": sessions[0]["last_ts"],
        })
    projects.sort(key=lambda p: p["last_ts"], reverse=True)
    return projects


def render_index():
    projects = scan_all()
    nsess = sum(len(p["sessions"]) for p in projects)
    rows_html = []
    for pi, p in enumerate(projects):
        items = []
        for si, m in enumerate(p["sessions"]):
            over = " over" if si >= 5 else ""
            color = COLOR.get((m["color"] or "").lower(), m["color"] or "#bbb")
            title = title_for(m)
            tw = ("<strong>", "</strong>") if m["custom_title"] else ("", "")
            sub = m["last_prompt"] if (m["last_prompt"] and m["last_prompt"] != title) else ""
